# portal-apme-values.yaml.template — render before helm install
#
# Fresh non-production greenfield. Use a new, empty namespace on a lab or EAP early access cluster.
# Helm applies the full dynamic.plugins list from the rendered file.
#
# Rendered by apme-portal-installer role apme_helm_values (placeholders below).
# Placeholders: <namespace> <cluster-router-base>
#   <preloaded-image-registry> <preloaded-image-repository> <preloaded-image-tag>
#
# APME plugins are pre-baked into the custom RHDH image built by apme_image_build.
# Plugin pack: addons/apme-eap/plugin_packs/apme-prototype-plugins-*.oci.tar.gz

redhat-developer-hub:
  common:
    exampleValue: common-chart
    global:
      _environment:
        _development: false
        _production: true
        _stage: false
      auth:
        backend:
          enabled: true
          existingSecret: ""
          value: ""
      catalogIndex:
        image:
          registry: registry.access.redhat.com
          repository: rhdh/plugin-catalog-index@sha256
          tag: 05ca260c6511bc49f619535f7ea56d58bb7bc5336daf6d5cff5b2f03e970fb44
      clusterRouterBase: apps.example.com
      dynamic:
        includes:
        - dynamic-plugins.default.yaml
        plugins:
        - disabled: false
          package: ./dynamic-plugins/dist/backstage-community-plugin-rbac
        - disabled: false
          integrity: '{{- include "plugins.integrity.scaffolder" . }}'
          package: '{{- include "plugins.load.scaffolder" . }}'
          pluginConfig:
            dynamicPlugins:
              backend:
                ansible.plugin-scaffolder-backend-module-backstage-rhaap: null
        - disabled: false
          integrity: '{{- include "plugins.integrity.catalog" . }}'
          package: '{{- include "plugins.load.catalog" . }}'
        - disabled: false
          integrity: '{{- include "plugins.integrity.self-service" . }}'
          package: '{{- include "plugins.load.self-service" . }}'
          pluginConfig:
            dynamicPlugins:
              frontend:
                ansible.plugin-backstage-self-service:
                  dynamicRoutes:
                  - importName: LandingPage
                    path: /
                  - importName: SelfServicePage
                    path: /self-service
                  - importName: TemplatesPage
                    menuItem:
                      importName: TemplatesSidebarItem
                    path: /self-service/*
                  - importName: HistoryPage
                    menuItem:
                      importName: HistorySidebarItem
                    path: /self-service/create/tasks
                  - importName: EEPage
                    path: /self-service/ee/*
                  - importName: EEPage
                    menuItem:
                      importName: EEBuilderSidebarItem
                    path: /self-service/ee
                  - importName: CollectionsPage
                    menuItem:
                      importName: CollectionsSidebarItem
                    path: /self-service/collections
                  - importName: CollectionsPage
                    path: /self-service/collections/*
                  - importName: GitRepositoriesPage
                    menuItem:
                      importName: GitRepositoriesSidebarItem
                    path: /self-service/repositories
                  - importName: GitRepositoriesPage
                    path: /self-service/repositories/*
                  mountPoints:
                  - importName: LocationListener
                    mountPoint: application/listener
                  - importName: AppThemeFixer
                    mountPoint: application/listener
                  - config:
                      priority: 100
                    importName: AAPLogoutButton
                    mountPoint: global.header/profile
                  providerSettings:
                  - description: Sign in with RHAAP
                    provider: ansible.auth.rhaap
                    title: RHAAP
                  scaffolderFieldExtensions:
                  - importName: AAPTokenFieldExtension
                  - importName: AAPResourcePickerExtension
                  - importName: AdditionalBuildStepsPickerFieldExtension
                  - importName: BaseImagePickerFieldExtension
                  - importName: CollectionsPickerFieldExtension
                  - importName: EEFileNamePickerExtension
                  - importName: FileUploadPickerFieldExtension
                  - importName: PackagesPickerFieldExtension
                  - importName: MCPServersPickerFieldExtension
                  - importName: ScmSelectorFieldExtension
                  signInPage:
                    importName: SignInPage
        - disabled: false
          integrity: '{{- include "plugins.integrity.auth" . }}'
          package: '{{- include "plugins.load.auth" . }}'
          pluginConfig: {}
        - disabled: false
          package: '{{- include "plugins.load.github-auth-provider" . }}'
        - disabled: false
          package: '{{- include "plugins.load.gitlab-auth-provider" . }}'
        - disabled: false
          package: ./dynamic-plugins/dist/backstage-plugin-scaffolder-backend-module-github-dynamic
        - disabled: false
          package: ./dynamic-plugins/dist/backstage-plugin-scaffolder-backend-module-gitlab-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/backstage-plugin-techdocs
        - disabled: true
          package: ./dynamic-plugins/dist/backstage-plugin-techdocs-backend-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/backstage-plugin-techdocs-module-addons-contrib
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-catalog-backend-module-marketplace-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-quickstart
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-adoption-insights
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-adoption-insights-backend-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-analytics-module-adoption-insights-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-dynamic-home-page
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-marketplace
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-marketplace-backend-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-extensions
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-catalog-backend-module-extensions-dynamic
        - disabled: true
          package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-extensions-backend-dynamic
      host: ""
      imageRegistry: ""
      imageTagInfo: "2.2"
      ociPluginImage: ""
      pluginMode: tarball
  global:
    _environment:
      _development: false
      _production: true
      _stage: false
    auth:
      backend:
        enabled: true
        existingSecret: ""
        value: ""
    catalogIndex:
      image:
        registry: registry.access.redhat.com
        repository: rhdh/plugin-catalog-index@sha256
        tag: 05ca260c6511bc49f619535f7ea56d58bb7bc5336daf6d5cff5b2f03e970fb44
    clusterRouterBase: <cluster-router-base>
    dynamic:
      includes:
      - dynamic-plugins.default.yaml
      plugins:
      - disabled: false
        package: ./dynamic-plugins/dist/backstage-community-plugin-rbac
      - disabled: false
        package: ./dynamic-plugins/dist/ansible-plugin-scaffolder-backend-module-backstage-rhaap
        pluginConfig:
          dynamicPlugins:
            backend:
              ansible.plugin-scaffolder-backend-module-backstage-rhaap: null
      - disabled: false
        package: ./dynamic-plugins/dist/ansible-backstage-plugin-catalog-backend-module-rhaap
      - disabled: false
        package: ./dynamic-plugins/dist/ansible-plugin-backstage-self-service
        pluginConfig:
          dynamicPlugins:
            frontend:
              ansible.plugin-backstage-self-service:
                dynamicRoutes:
                - importName: LandingPage
                  path: /
                - importName: SelfServicePage
                  path: /self-service
                - importName: TemplatesPage
                  menuItem:
                    importName: TemplatesSidebarItem
                  path: /self-service/*
                - importName: HistoryPage
                  menuItem:
                    importName: HistorySidebarItem
                  path: /self-service/create/tasks
                - importName: EEPage
                  path: /self-service/ee/*
                - importName: EEPage
                  menuItem:
                    importName: EEBuilderSidebarItem
                  path: /self-service/ee
                - importName: CollectionsPage
                  menuItem:
                    importName: CollectionsSidebarItem
                  path: /self-service/collections
                - importName: CollectionsPage
                  path: /self-service/collections/*
                - importName: GitRepositoriesPage
                  menuItem:
                    importName: GitRepositoriesSidebarItem
                  path: /self-service/repositories
                - importName: GitRepositoriesPage
                  path: /self-service/repositories/*
                mountPoints:
                - importName: LocationListener
                  mountPoint: application/listener
                - importName: AppThemeFixer
                  mountPoint: application/listener
                - config:
                    priority: 100
                  importName: AAPLogoutButton
                  mountPoint: global.header/profile
                providerSettings:
                - description: Sign in with RHAAP
                  provider: ansible.auth.rhaap
                  title: RHAAP
                scaffolderFieldExtensions:
                - importName: AAPTokenFieldExtension
                - importName: AAPResourcePickerExtension
                - importName: AdditionalBuildStepsPickerFieldExtension
                - importName: BaseImagePickerFieldExtension
                - importName: CollectionsPickerFieldExtension
                - importName: EEFileNamePickerFieldExtension
                - importName: FileUploadPickerFieldExtension
                - importName: PackagesPickerFieldExtension
                - importName: MCPServersPickerFieldExtension
                - importName: ScmSelectorFieldExtension
                signInPage:
                  importName: SignInPage
      - disabled: false
        package: ./dynamic-plugins/dist/ansible-backstage-plugin-auth-backend-module-rhaap-provider
        pluginConfig: {}
      - disabled: false
        package: ./dynamic-plugins/dist/ansible-plugin-backstage-apme
        pluginConfig:
          dynamicPlugins:
            frontend:
              ansible.plugin-backstage-apme:
                apiFactories:
                - importName: gitRepositoriesExtensionsApiFactory
                appIcons:
                - importName: SecurityIcon
                  module: '@material-ui/icons'
                  name: apmeIcon
      - disabled: false
        package: ./dynamic-plugins/dist/ansible-backstage-plugin-catalog-backend-module-apme
        pluginConfig:
          dynamicPlugins:
            backend:
              ansible.backstage-plugin-catalog-backend-module-apme: {}
      - disabled: false
        package: '{{- include "plugins.load.github-auth-provider" . }}'
      - disabled: false
        package: '{{- include "plugins.load.gitlab-auth-provider" . }}'
      - disabled: false
        package: ./dynamic-plugins/dist/backstage-plugin-scaffolder-backend-module-github-dynamic
      - disabled: false
        package: ./dynamic-plugins/dist/backstage-plugin-scaffolder-backend-module-gitlab-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/backstage-plugin-techdocs
      - disabled: true
        package: ./dynamic-plugins/dist/backstage-plugin-techdocs-backend-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/backstage-plugin-techdocs-module-addons-contrib
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-catalog-backend-module-marketplace-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-quickstart
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-adoption-insights
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-adoption-insights-backend-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-analytics-module-adoption-insights-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-dynamic-home-page
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-marketplace
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-marketplace-backend-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-extensions
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-catalog-backend-module-extensions-dynamic
      - disabled: true
        package: ./dynamic-plugins/dist/red-hat-developer-hub-backstage-plugin-extensions-backend-dynamic
    host: ""
    imageRegistry: ""
    imageTagInfo: "2.2"
    ociPluginImage: ""
    pluginMode: oci
  nameOverride: rhaap-portal
  orchestrator:
    enabled: false
    plugins:
    - disabled: false
      package: oci://registry.access.redhat.com/rhdh/red-hat-developer-hub-backstage-plugin-orchestrator-backend:{{
        "{{inherit}}" }}
    - disabled: false
      package: oci://registry.access.redhat.com/rhdh/red-hat-developer-hub-backstage-plugin-orchestrator-form-widgets:{{
        "{{inherit}}" }}
    - disabled: false
      package: oci://registry.access.redhat.com/rhdh/red-hat-developer-hub-backstage-plugin-orchestrator:{{
        "{{inherit}}" }}
    - disabled: false
      package: oci://registry.access.redhat.com/rhdh/red-hat-developer-hub-backstage-plugin-scaffolder-backend-module-orchestrator:{{
        "{{inherit}}" }}
    serverlessLogicOperator:
      enabled: true
    serverlessOperator:
      enabled: true
    sonataflowPlatform:
      createDBJobImage: '{{ .Values.upstream.postgresql.image.registry }}/{{ .Values.upstream.postgresql.image.repository
        }}:{{ .Values.upstream.postgresql.image.tag }}'
      dataIndexImage: ""
      eventing:
        broker:
          name: ""
          namespace: ""
      externalDBHost: ""
      externalDBName: ""
      externalDBPort: ""
      externalDBsecretRef: ""
      initContainerImage: '{{ .Values.upstream.postgresql.image.registry }}/{{ .Values.upstream.postgresql.image.repository
        }}:{{ .Values.upstream.postgresql.image.tag }}'
      jobServiceImage: ""
      monitoring:
        enabled: true
      resources:
        limits:
          cpu: 500m
          memory: 1Gi
        requests:
          cpu: 250m
          memory: 64Mi
  route:
    annotations: {}
    enabled: true
    host: '{{ .Values.global.host }}'
    path: /
    tls:
      caCertificate: ""
      certificate: ""
      destinationCACertificate: ""
      enabled: true
      insecureEdgeTerminationPolicy: Redirect
      key: ""
      termination: edge
    wildcardPolicy: None
  test:
    enabled: false
    image:
      registry: quay.io
      repository: curl/curl
      tag: latest
    injectTestNpmrcSecret: false
  upstream:
    backstage:
      affinity: {}
      annotations: {}
      appConfig:
        ansible:
          apme:
            baseUrl: http://apme-gateway:8080
            checkSSL: false
            enabled: true
            mockMode: false
          creatorService:
            baseUrl: 127.0.0.1
            port: "8000"
          # OpenShift Dev Spaces — optional; set devspaces_base_url in vars to enable.
          # <devspaces-config>
          # Private Automation Hub / Galaxy UI (AAP gateway hosts /api/galaxy)
          automationHub:
            baseUrl: ${AAP_HOST_URL}
          feedback:
            enabled: false
          rhaap:
            baseUrl: ${AAP_HOST_URL}
            checkSSL: true
            token: ${AAP_TOKEN}
        app:
          baseUrl: https://{{- include "rhdh.hostname" . }}
          branding:
            fullLogo:
              dark: data:image/svg+xml;base64,
              light: data:image/svg+xml;base64,
            iconLogo: data:image/svg+xml;base64,
          sidebar:
            logo: true
            search: false
            settings: false
          title: Ansible automation portal
        auth:
          environment: production
          omitIdentityTokenOwnershipClaim: true
          providers:
            github:
              production:
                clientId: ${GITHUB_OAUTH_CLIENT_ID}
                clientSecret: ${GITHUB_OAUTH_CLIENT_SECRET}
            rhaap:
              production:
                checkSSL: true
                clientId: ${OAUTH_CLIENT_ID}
                clientSecret: ${OAUTH_CLIENT_SECRET}
                host: ${AAP_HOST_URL}
                signIn:
                  resolvers:
                  - resolver: allowNewAAPUserSignIn
          signInPage: rhaap
        backend:
          auth:
            externalAccess:
            - options:
                secret: ${BACKEND_SECRET}
                subject: legacy-default-config
              type: legacy
          baseUrl: https://{{- include "rhdh.hostname" . }}
          cors:
            origin: https://{{- include "rhdh.hostname" . }}
          database:
            connection:
              password: ${POSTGRESQL_ADMIN_PASSWORD}
              user: postgres
          reading:
            allow:
            - host: gitlab.com
            - host: github.com
            - host: raw.githubusercontent.com
            - host: localhost
          request:
            bodyParsing:
              sizeLimit: 10mb
        catalog:
          import:
            entityFilename: catalog-info.yaml
            pullRequestBranchName: backstage-integration
          locations:
          - rules:
            - allow:
              - Template
            target: https://github.com/ansible/ansible-rhdh-templates/blob/v2.0.0/templates/ee-start-from-scratch.yaml
            type: url
          - rules:
            - allow:
              - Template
            target: /opt/app-root/src/configs/extra-files/apme-register-git-repository/template.yaml
            type: file
          orphanStrategy: delete
          processingInterval:
            minutes: 30
          providers:
            rhaap:
              '{{- include "catalog.providers.env" . }}':
                orgs: Default
                sync:
                  ansibleGitContents:
                    enabled: true
                    schedule:
                      frequency:
                        minutes: 30
                      timeout:
                        minutes: 30
                    # Register discovered repos as APME projects (scans stay user-initiated)
                    apme:
                      enabled: true
                      scanOnRegister: false
                      maxPerRun: 10
                      schedule:
                        frequency:
                          minutes: 60
                        timeout:
                          minutes: 30
                    providers:
                      github:
                      - host: github.com
                        name: github-acme-scm
                        orgs:
                        - name: acme-scm
                          branches:
                          - main
                          - master
                          crawlDepth: 5
                          apme:
                            enabled: true
                            scanOnRegister: false
                          schedule:
                            frequency:
                              minutes: 30
                            timeout:
                              minutes: 30
                      # Clear chart-default gitlab org crawl (maps deep-merge)
                      gitlab: []
                  jobTemplates:
                    enabled: true
                    schedule:
                      frequency:
                        minutes: 60
                      timeout:
                        seconds: 30
                  orgsUsersTeams:
                    schedule:
                      frequency:
                        minutes: 60
                      timeout:
                        seconds: 30
                  pahCollections:
                    enabled: false
                    repositories:
                    - name: rh-certified
                      schedule:
                        frequency:
                          days: 1
                        timeout:
                          minutes: 60
                    - name: validated
                      schedule:
                        frequency:
                          days: 1
                        timeout:
                          minutes: 60
                    - name: published
                      schedule:
                        frequency:
                          days: 1
                        timeout:
                          minutes: 60
          rules:
          - allow:
            - Component
            - System
            - Group
            - Resource
            - Location
            - Template
            - API
            - Users
          stitchingStrategy:
            mode: immediate
        dynamicPlugins:
          frontend:
            default.main-menu-items:
              menuItems:
                default.apis:
                  icon: extension
                  priority: 60
                  title: ""
                  to: api-docs
                default.catalog:
                  icon: category
                  priority: 80
                  title: ""
                  to: catalog
                default.create:
                  icon: add
                  priority: 40
                  title: ""
                  to: create
                default.home:
                  icon: home
                  priority: 90
                  title: ""
                  to: /
                default.learning-path:
                  icon: school
                  priority: 50
                  title: ""
                  to: learning-paths
                default.my-group:
                  icon: group
                  priority: 70
                  title: ""
            internal.plugin-dynamic-plugins-info:
              appIcons:
              - importName: PluginsInfoIcon
                name: pluginsInfoIcon
              - importName: AdminIcon
                name: adminIcon
              menuItems:
                admin:
                  icon: adminIcon
                  title: Administration
                plugins:
                  icon: pluginsInfoIcon
                  parent: admin
                  title: ""
                  to: rbac
            red-hat-developer-hub.backstage-plugin-global-header:
              mountPoints:
              - config:
                  position: above-main-content
                importName: GlobalHeader
                mountPoint: application/header
              - config:
                  priority: 99
                  props:
                    growFactor: 1
                importName: Spacer
                mountPoint: global.header/component
              - config:
                  priority: 85
                  props:
                    icon: support
                    title: Support
                    to: ${CUSTOMER_SUPPORT_URL}
                importName: HeaderIconButton
                mountPoint: global.header/component
              - config:
                  priority: 50
                importName: Divider
                mountPoint: global.header/component
              - config:
                  priority: 10
                importName: ProfileDropdown
                mountPoint: global.header/component
        enableExperimentalRedirectFlow: true
        integrations:
          github:
          - host: github.com
            token: ${GITHUB_TOKEN}
            apps:
            - appId: ${GITHUB_APP_ID}
              clientId: ${GITHUB_APP_CLIENT_ID}
              clientSecret: ${GITHUB_APP_CLIENT_SECRET}
              privateKey: |
                ${GITHUB_APP_PRIVATE_KEY}
          gitlab:
          - host: gitlab.com
            token: ${GITLAB_TOKEN}
        permission:
          enabled: true
          rbac:
            admin:
              superUsers:
              - name: user:default/admin
              - name: group:default/aap-admins
              users:
              - name: user:default/admin
              - name: group:default/aap-admins
            pluginsWithPermission:
            - catalog
            - scaffolder
            - permission
      args:
      - --config
      - dynamic-plugins-root/app-config.dynamic-plugins.yaml
      autoscaling:
        enabled: false
        maxReplicas: 100
        minReplicas: 1
        targetCPUUtilizationPercentage: 80
      command: []
      containerPorts:
        backend: 7007
      containerSecurityContext:
        allowPrivilegeEscalation: false
        capabilities:
          drop:
          - ALL
        readOnlyRootFilesystem: true
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      extraAppConfig: []
      extraContainers:
      - command:
        - adt
        - server
        image: '{{- include "deployment.container-image" . }}'
        imagePullPolicy: IfNotPresent
        name: ansible-devtools-server
        ports:
        - containerPort: 8000
      extraEnvVars:
      - name: BACKEND_SECRET
        valueFrom:
          secretKeyRef:
            key: backend-secret
            name: '{{ include "janus-idp.backend-secret-name" $ }}'
      - name: POSTGRESQL_ADMIN_PASSWORD
        valueFrom:
          secretKeyRef:
            key: '{{ .Values.postgresql.auth.secretKeys.adminPasswordKey | default
              "postgres-password" }}'
            name: '{{- include "janus-idp.postgresql.secretName" . }}'
      - name: ENABLE_AUTH_PROVIDER_MODULE_OVERRIDE
        value: "true"
      - name: SEGMENT_WRITE_KEY
        value: uCMHvkR5n5q2v57LNXHwvTYlGV8lqFR9
      - name: AAP_HOST_URL
        valueFrom:
          secretKeyRef:
            key: aap-host-url
            name: secrets-rhaap-portal
      - name: OAUTH_CLIENT_ID
        valueFrom:
          secretKeyRef:
            key: oauth-client-id
            name: secrets-rhaap-portal
      - name: OAUTH_CLIENT_SECRET
        valueFrom:
          secretKeyRef:
            key: oauth-client-secret
            name: secrets-rhaap-portal
      - name: GITHUB_OAUTH_CLIENT_ID
        valueFrom:
          secretKeyRef:
            key: github-oauth-client-id
            name: secrets-scm
            optional: true
      - name: GITHUB_OAUTH_CLIENT_SECRET
        valueFrom:
          secretKeyRef:
            key: github-oauth-client-secret
            name: secrets-scm
            optional: true
      - name: GITLAB_OAUTH_CLIENT_ID
        valueFrom:
          secretKeyRef:
            key: gitlab-oauth-client-id
            name: secrets-scm
            optional: true
      - name: GITLAB_OAUTH_CLIENT_SECRET
        valueFrom:
          secretKeyRef:
            key: gitlab-oauth-client-secret
            name: secrets-scm
            optional: true
      - name: AAP_TOKEN
        valueFrom:
          secretKeyRef:
            key: aap-token
            name: secrets-rhaap-portal
      - name: GITHUB_TOKEN
        valueFrom:
          secretKeyRef:
            key: github-token
            name: secrets-scm
            optional: true
      - name: GITLAB_TOKEN
        valueFrom:
          secretKeyRef:
            key: gitlab-token
            name: secrets-scm
            optional: true
      - name: GITHUB_APP_ID
        valueFrom:
          secretKeyRef:
            key: github-app-id
            name: secrets-scm
            optional: true
      - name: GITHUB_APP_CLIENT_ID
        valueFrom:
          secretKeyRef:
            key: github-app-client-id
            name: secrets-scm
            optional: true
      - name: GITHUB_APP_CLIENT_SECRET
        valueFrom:
          secretKeyRef:
            key: github-app-client-secret
            name: secrets-scm
            optional: true
      - name: GITHUB_APP_PRIVATE_KEY
        valueFrom:
          secretKeyRef:
            key: github-app-private-key
            name: secrets-scm
            optional: true
      - name: CUSTOMER_SUPPORT_URL
        value: https://access.redhat.com/support
      extraEnvVarsCM: []
      extraEnvVarsSecrets: []
      extraPorts: []
      extraVolumeMounts:
