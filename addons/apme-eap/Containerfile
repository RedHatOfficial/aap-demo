# Build a custom RHDH image with APME plugins pre-extracted at build time.
#
# The .oci.tar.gz plugin pack is a Docker archive: a tar containing manifest.json
# and per-layer tar files. We extract all layers to reconstruct the plugin
# filesystem, copy each plugin directory to dynamic-plugins/dist/, then clean up.
# At runtime the init container reads ./dynamic-plugins/dist/<plugin> as a fast
# local copy instead of pulling from an OCI registry.
#
# Usage (driven by the apme_image_build Ansible role):
#   podman build \
#     --build-arg BASE_IMAGE=registry.redhat.io/rhdh/rhdh-hub-rhel9:1.9 \
#     -t rhdh-apme-preloaded:<plugin-sha> \
#     -f Containerfile .
#
# Build context must be addons/apme-eap/ so plugin_packs/ is accessible.

ARG BASE_IMAGE=registry.redhat.io/rhdh/rhdh-hub-rhel9:1.9
FROM ${BASE_IMAGE}

USER root

COPY plugin_packs/apme-prototype-plugins-*.oci.tar.gz /tmp/plugin-pack.tar.gz

# Extract all Docker archive layers in order, copy plugin dirs to dist/, clean up.
# Uses only Python stdlib (gzip + tarfile) — no gzip/tar binaries required.
RUN python3 - <<'PYEOF'
import gzip, json, os, shutil, tarfile

ARCHIVE = "/tmp/plugin-pack.tar.gz"
WORK    = "/tmp/apme-archive"
OUT     = "/tmp/apme-extracted"
DIST    = "/opt/app-root/src/dynamic-plugins/dist"
PLUGINS = [
    "ansible-plugin-scaffolder-backend-module-backstage-rhaap",
    "ansible-backstage-plugin-catalog-backend-module-rhaap",
    "ansible-plugin-backstage-self-service",
    "ansible-backstage-plugin-auth-backend-module-rhaap-provider",
    "ansible-plugin-backstage-apme",
    "ansible-backstage-plugin-catalog-backend-module-apme",
]

os.makedirs(WORK, exist_ok=True)
os.makedirs(OUT,  exist_ok=True)

# Step 1: decompress and unpack the outer Docker archive
print("Unpacking Docker archive...", flush=True)
with gzip.open(ARCHIVE, "rb") as gz:
    with tarfile.open(fileobj=gz) as outer:
        outer.extractall(WORK)

# Step 2: read manifest.json to find layer tarballs, extract in order
with open(os.path.join(WORK, "manifest.json")) as f:
    manifest = json.load(f)

layers = manifest[0]["Layers"]
print(f"Extracting {len(layers)} layer(s)...", flush=True)
for layer in layers:
    print(f"  {layer}", flush=True)
    with tarfile.open(os.path.join(WORK, layer)) as lt:
        lt.extractall(OUT)

# Step 3: copy each plugin directory into dynamic-plugins/dist/
for plugin in PLUGINS:
    src = os.path.join(OUT, plugin)
    dst = os.path.join(DIST, plugin)
    if os.path.isdir(src):
        shutil.copytree(src, dst)
        print(f"Installed {plugin}", flush=True)
    else:
        print(f"WARNING: {plugin} not found in extracted image", flush=True)

# Step 4: clean up build artifacts
shutil.rmtree(WORK)
shutil.rmtree(OUT)
os.remove(ARCHIVE)
PYEOF

USER 1001
