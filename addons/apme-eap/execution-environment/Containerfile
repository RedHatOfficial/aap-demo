# Alternative Containerfile for building without ansible-builder
# Can be built directly with: podman build -f Containerfile -t apme-ee:latest .

FROM registry.redhat.io/ansible-automation-platform-27/ee-supported-rhel9:latest

USER root

# Install OpenShift CLI and Skopeo
RUN microdnf install -y openshift-clients skopeo && \
    microdnf clean all

# Verify installations
RUN oc version --client && skopeo --version

USER 1000

LABEL description="APME Execution Environment with oc and skopeo"
LABEL maintainer="aap-demo"
